{
    "name": "rathena-language-support",
    "displayName": "rAthena Language Support",
    "description": "Adds syntax highlighting and code snippets for the rAthena Scripting Language",
    "publisher": "rAthena",
    "icon": "rathena-icon.avif",
    "repository": {
        "type": "git",
        "url": "https://github.com/rathena/vsce-rathena-language-support"
    },
    "author": {
        "name": "rAthena Dev Team"
    },
    "contributors": [
        {
            "name": "JoWei",
            "url": "https://github.com/JoWei"
        },
        {
            "name": "Jittapan Pleumsumran",
            "url": "https://github.com/secretdataz/athena-language-support"
        },
        {
            "name": "rAthena Developers",
            "url": "https://github.com/rathena/"
        }
    ],
    "license": "MIT",
    "private": false,
    "bugs": {
        "url": "https://github.com/rathena/vsce-rathena-language-support/issues"
    },
    "version": "1.1.3",
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension",
    "contributes": {
        "languages": [
            {
                "id": "rathena",
                "aliases": [
                    "rAthena",
                    "rathena"
                ],
                "extensions": [
                    ".rascript"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "commands": [
            {
                "command": "rathena.wrapWithColorCodes",
                "title": "Wrap in Color Codes"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "when": "editorHasSelection && editorLangId == rathena",
                    "command": "rathena.wrapWithColorCodes",
                    "group": "1_modification"
                }
            ]
        },
        "grammars": [
            {
                "language": "rathena",
                "scopeName": "source.rathena",
                "path": "./syntaxes/rathena.json"
            }
        ],
        "snippets": [
            {
                "language": "rathena",
                "path": "./snippets/rathena.json"
            }
        ],
        "configuration": {
            "title": "rAthena Script Syntax",
            "properties": {
                "rathena.renderColors": {
                    "type": "boolean",
                    "default": true,
                    "description": "Render color codes in text",
                    "order": 1
                },
                "rathena.hideColorCodes": {
                    "type": "boolean",
                    "default": true,
                    "description": "Hide color codes (^xxxxxx) until selected. This option requires 'Render Colors' to be enabled.",
                    "order": 2,
                    "when": "config.rathena.renderColors"
                },
                "rathena.showColorPicker": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show color picker for color codes",
                    "order": 3
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "lint": "eslint \"src/**/*.ts\"",
        "watch": "tsc -watch -p ./",
        "test": "mocha"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^16.18.126",
        "@types/vscode": "^1.120.0",
        "@typescript-eslint/eslint-plugin": "^5.59.2",
        "@typescript-eslint/parser": "^5.42.0",
        "eslint": "^8.39.0",
        "eslint-config-standard-with-typescript": "^34.0.1",
        "eslint-plugin-import": "^2.27.5",
        "eslint-plugin-n": "^15.7.0",
        "eslint-plugin-promise": "^6.1.1",
        "mocha": "^10.8.2",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.4"
    }
}
